apiVersion: v1
kind: Secret
metadata:
  name: wallet-credentials
  namespace: crypto-demo
type: Opaque
stringData:
  BTC_XPUB: "zpub..."
  LTC_XPUB: "zpub..."
  BITCOIND_RPC_USER: "bitcoin"
  BITCOIND_RPC_PASSWORD: "changeme"
  LITECOIND_RPC_USER: "litecoin"
  LITECOIND_RPC_PASSWORD: "changeme"
  # Comma-separated mainnet XMR daemon addresses, host:port format (no http://).
  # First entry must match --daemon-address in xmr-wallet/deployment.yaml.
  XMR_DAEMON_NODES: "abc123.onion:18089,def456.onion:18089,ghi789.onion:18089"
  # SOCKS5 proxy for onion addresses — matches the Tor service name in the cluster
  XMR_TOR_PROXY: "tor:9050"
