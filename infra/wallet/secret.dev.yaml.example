apiVersion: v1
kind: Secret
metadata:
  name: wallet-credentials
  namespace: crypto-demo
type: Opaque
stringData:
  # Dev (regtest) zpubs — generate from an Electrum testnet wallet (native segwit).
  # BTC and LTC share the same vpub format for both testnet and regtest.
  BTC_XPUB: "vpub..."
  LTC_XPUB: "vpub..."
  BITCOIND_RPC_USER: "bitcoin"
  BITCOIND_RPC_PASSWORD: "changeme"
  LITECOIND_RPC_USER: "litecoin"
  LITECOIND_RPC_PASSWORD: "changeme"
  # Stagenet XMR daemon (clearnet, no Tor needed for testing)
  XMR_DAEMON_NODES: "node2.monerodevs.org:38089"
  XMR_TOR_PROXY: ""
