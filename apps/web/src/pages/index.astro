---
import Layout from '../layouts/Layout.astro';

const token = Astro.cookies.get('token')?.value;
const isLoggedIn = !!token;

const API_URL = process.env.API_URL || 'http://api:3000';

// Handle delete account
if (Astro.request.method === 'POST' && token) {
  const form = await Astro.request.formData();
  if (form.get('_action') === 'delete-account') {
    await fetch(`${API_URL}/api/users/me`, {
      method: 'DELETE',
      headers: { Authorization: `Bearer ${token}` },
    }).catch(() => {});
    Astro.cookies.delete('token', { path: '/' });
    return Astro.redirect('/login');
  }
}

// Decode username from JWT payload (display only — auth is handled by the API)
let username: string | null = null;
if (token) {
  try {
    username = JSON.parse(atob(token.split('.')[1])).username ?? null;
  } catch { /* ignore */ }
}

let balanceSats: string | null = null;
let balanceBtc: string | null = null;

if (isLoggedIn && token) {
  try {
    const res = await fetch(`${API_URL}/api/deposits/balance`, {
      headers: { Authorization: `Bearer ${token}` },
    });
    if (res.ok) {
      const data = (await res.json()) as { balanceSats: string };
      balanceSats = data.balanceSats;
      balanceBtc = (Number(data.balanceSats) / 1e8).toFixed(8);
    }
  } catch {
    // best-effort
  }
}
---

<Layout title="Crypto Demo">
  <div class="min-h-screen flex flex-col items-center justify-center p-4">
    <div class="card w-full max-w-md bg-base-100 shadow-xl">
      <div class="card-body gap-4">
        <h1 class="card-title text-2xl">Crypto Demo</h1>

        {isLoggedIn ? (
          <>
            <p class="font-medium">
              Hello, <span class="text-primary font-semibold">{username}</span>
            </p>

            {balanceSats !== null && (
              <div class="stats shadow w-full">
                <div class="stat">
                  <div class="stat-title">Balance</div>
                  <div class="stat-value text-primary text-xl">{balanceBtc} BTC</div>
                  <div class="stat-desc">{Number(balanceSats).toLocaleString()} sats</div>
                </div>
              </div>
            )}

            <div class="card-actions flex-wrap gap-2">
              <a href="/wallet" class="btn btn-primary">Wallet</a>
              <a href="/logout" class="btn btn-outline btn-sm">Log out</a>
            </div>

            <div class="divider"></div>

            <form method="POST">
              <input type="hidden" name="_action" value="delete-account" />
              <button
                type="submit"
                class="btn btn-error btn-outline btn-sm"
                onclick="return confirm('Permanently delete your account and all data? This cannot be undone.')"
              >
                Delete account
              </button>
            </form>
          </>
        ) : (
          <div class="card-actions">
            <a href="/login" class="btn btn-primary">Log in</a>
            <a href="/signup" class="btn btn-outline">Sign up</a>
          </div>
        )}
      </div>
    </div>
  </div>
</Layout>
