---
import Layout from '../layouts/Layout.astro';
import { getPrices, usdToSats, usdToLitoshis, usdToPiconeros } from '../lib/prices';

const token = Astro.cookies.get('token')?.value;
if (!token) return Astro.redirect('/login');

const API_URL = process.env.API_URL || 'http://api:3000';
let errorMessage = '';
let existingInvoice: { invoiceId: string; amountSats: string; address: string; currency: string } | null = null;

const prices = await getPrices();

if (Astro.request.method === 'POST') {
  const formData = await Astro.request.formData();
  const amountUsd = Number(formData.get('amountUsd'));
  const currency = formData.get('currency') as string;

  const amountSats =
    currency === 'XMR' ? usdToPiconeros(amountUsd, prices.xmrUsd) :
    currency === 'LTC' ? usdToLitoshis(amountUsd, prices.ltcUsd) :
    usdToSats(amountUsd, prices.btcUsd);

  try {
    const res = await fetch(`${API_URL}/api/deposits`, {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        Authorization: `Bearer ${token}`,
      },
      body: JSON.stringify({ amountSats, currency }),
    });

    if (res.status === 409) {
      const body = (await res.json().catch(() => ({}))) as {
        invoiceId?: string;
        amountSats?: string;
        address?: string;
        currency?: string;
      };
      if (body.invoiceId) {
        existingInvoice = {
          invoiceId: body.invoiceId,
          amountSats: body.amountSats ?? '0',
          address: body.address ?? '',
          currency: body.currency ?? currency,
        };
        errorMessage = `You already have a pending ${existingInvoice.currency} deposit.`;
      }
    } else if (!res.ok) {
      const body = await res.json().catch(() => ({}));
      errorMessage =
        (body as { message?: string }).message ?? `Request failed with status ${res.status}`;
    } else {
      const data = (await res.json()) as {
        invoiceId: string;
        amountSats: string;
        address: string;
        currency: string;
        status: string;
      };
      return Astro.redirect(
        `/deposit/${data.invoiceId}?address=${encodeURIComponent(data.address)}&amountSats=${encodeURIComponent(data.amountSats)}&currency=${data.currency}`,
      );
    }
  } catch (err) {
    errorMessage = err instanceof Error ? err.message : 'Network error';
  }
}
---

<Layout title="Deposit">
  <div class="min-h-screen flex flex-col items-center justify-center p-4">
    <div class="card w-full max-w-md bg-base-100 shadow-xl">
      <div class="card-body gap-4">
        <h1 class="card-title text-2xl">Deposit</h1>

        {errorMessage && (
          <div class="alert alert-warning flex flex-col items-start gap-1">
            <span>{errorMessage}</span>
            {existingInvoice && (
              <a
                href={`/deposit/${existingInvoice.invoiceId}?amountSats=${existingInvoice.amountSats}&address=${encodeURIComponent(existingInvoice.address)}&currency=${existingInvoice.currency}`}
                class="btn btn-sm btn-outline"
              >
                View existing {existingInvoice.currency} deposit →
              </a>
            )}
          </div>
        )}

        <form method="POST" class="flex flex-col gap-4">
          <div class="form-control">
            <label class="label" for="currency">
              <span class="label-text">Currency</span>
            </label>
            <select id="currency" name="currency" class="select select-bordered w-full" required>
              <option value="BTC">Bitcoin (BTC)</option>
              <option value="LTC">Litecoin (LTC)</option>
              <option value="XMR">Monero (XMR)</option>
            </select>
          </div>

          <div class="form-control">
            <label class="label" for="amountUsd">
              <span class="label-text">Amount (USD)</span>
            </label>
            <div class="relative">
              <span class="absolute left-3 top-1/2 -translate-y-1/2 text-base-content/60 pointer-events-none">$</span>
              <input
                id="amountUsd"
                name="amountUsd"
                type="number"
                min="20"
                max="10000"
                step="0.01"
                placeholder="20.00"
                required
                class="input input-bordered w-full pl-7"
              />
            </div>
            <label class="label">
              <span id="min-hint" class="label-text-alt text-base-content/50">Minimum $20 for BTC — on-chain fees make smaller deposits uneconomical.</span>
            </label>
          </div>

          <div class="bg-base-200 rounded-lg p-3 text-sm flex flex-col gap-1">
            <div class="flex justify-between text-base-content/60">
              <span>Rate</span>
              <span id="rate-display">—</span>
            </div>
            <div class="flex justify-between font-medium">
              <span class="text-base-content/60">You'll deposit</span>
              <span id="units-display" class="select-all cursor-text">—</span>
            </div>
          </div>

          <button type="submit" class="btn btn-primary w-full">
            Generate Payment Address
          </button>
        </form>

        <div class="card-actions justify-start">
          <a href="/" class="btn btn-ghost btn-sm">Back to home</a>
        </div>
      </div>
    </div>
  </div>
</Layout>

<script define:vars={{ btcUsd: prices.btcUsd, ltcUsd: prices.ltcUsd, xmrUsd: prices.xmrUsd }}>
  const currencySelect = document.getElementById('currency');
  const amountInput = document.getElementById('amountUsd');
  const rateDisplay = document.getElementById('rate-display');
  const unitsDisplay = document.getElementById('units-display');
  const minHint = document.getElementById('min-hint');

  const rates = { BTC: btcUsd, LTC: ltcUsd, XMR: xmrUsd };
  const minimums = {
    BTC: { value: 20,  hint: 'Minimum $20 for BTC — on-chain fees make smaller deposits uneconomical.' },
    LTC: { value: 5,   hint: 'Minimum $5 for LTC — transaction fees are low.' },
    XMR: { value: 5,   hint: 'Minimum $5 for XMR — Monero fees are low.' },
  };

  function update() {
    const currency = currencySelect.value;
    const usd = parseFloat(amountInput.value);
    const rate = rates[currency];
    const min = minimums[currency];

    amountInput.min = String(min.value);
    if (minHint) minHint.textContent = min.hint;
    if (Number(amountInput.value) > 0 && Number(amountInput.value) < min.value) amountInput.value = '';

    rateDisplay.textContent = `1 ${currency} = $${rate.toLocaleString('en-US', { maximumFractionDigits: 2 })}`;

    if (!isNaN(usd) && usd > 0) {
      const decimals = currency === 'XMR' ? 12 : 8;
      const coin = (usd / rate).toFixed(decimals).replace(/\.?0+$/, '');
      unitsDisplay.textContent = `${coin} ${currency}`;
    } else {
      unitsDisplay.textContent = '—';
    }
  }

  currencySelect.addEventListener('change', update);
  amountInput.addEventListener('input', update);
  update();
</script>
