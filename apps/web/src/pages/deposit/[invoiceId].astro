---
import Layout from '../../layouts/Layout.astro';
import { getPrices, satsToUsd, litoshisToUsd, piconerosToUsd, formatUsd } from '../../lib/prices';

const token = Astro.cookies.get('token')?.value;
if (!token) return Astro.redirect('/login');

const { invoiceId } = Astro.params;
const urlParams = new URL(Astro.request.url).searchParams;
const address = urlParams.get('address') ?? '';
const amountSatsRaw = urlParams.get('amountSats') ?? '0';
const currency = urlParams.get('currency') ?? 'BTC';
const amountSats = Number(amountSatsRaw);
const [divisor, decimals] = currency === 'XMR' ? [1e12, 12] : [1e8, 8];
const amountDecimal = (amountSats / divisor).toFixed(decimals).replace(/\.?0+$/, '');

const prices = await getPrices();
const amountUsd = formatUsd(
  currency === 'XMR' ? piconerosToUsd(amountSats, prices.xmrUsd) :
  currency === 'LTC' ? litoshisToUsd(amountSats, prices.ltcUsd) :
  satsToUsd(amountSats, prices.btcUsd),
);

const PUBLIC_API_URL = import.meta.env.PUBLIC_API_URL || '';
const isRegtest = process.env.NETWORK === 'regtest';

// Confirmations required to settle — must mirror nbxplorer-poller.service.ts and xmr-poller.service.ts
const required = currency === 'XMR' ? 10 : currency === 'LTC' ? 6 : 2;

// Mine 1 block at a time so users can watch confirmations increment
// First mine sends funds to the deposit address (creates the payment tx).
// Subsequent mines go to a throwaway address so only one coinbase tx lands
// on the deposit address — subsequent blocks just add confirmations to it.
const cli = currency === 'LTC'
  ? `kubectl exec -n crypto-demo deployment/litecoind -- litecoin-cli -regtest -rpcuser=litecoin -rpcpassword=changeme`
  : `kubectl exec -n crypto-demo deployment/bitcoind -- bitcoin-cli -regtest -rpcuser=bitcoin -rpcpassword=changeme`;
const mineCmd =
  `${cli} generatetoaddress 1 ${address}   # run once to send funds\n` +
  `${cli} generatetoaddress 1 $(${cli} getnewaddress)  # run ${required - 1}× more to confirm`;

const confirmHint =
  currency === 'XMR'
    ? `Each Monero block takes ~2 minutes. Your payment will be credited after ${required} confirmations (~${required * 2} min).`
    : currency === 'LTC'
    ? `Each Litecoin block takes ~2.5 minutes. Your payment will be credited after ${required} confirmations (~${Math.round(required * 2.5)} min).`
    : `Each Bitcoin block takes ~10 minutes. Your payment will be credited after ${required} confirmations (~${required * 10} min).`;
---

<Layout title="Pay Invoice">
  <div class="min-h-screen flex flex-col items-center justify-center p-4">
    <div class="card w-full max-w-lg bg-base-100 shadow-xl">
      <div class="card-body gap-5">
        <div class="flex items-center justify-between">
          <h1 class="card-title text-2xl">{currency} Payment</h1>
          <span id="status-badge" class="badge badge-warning badge-lg">waiting</span>
        </div>

        <div id="success-alert" class="alert alert-success hidden">
          <svg xmlns="http://www.w3.org/2000/svg" class="stroke-current shrink-0 h-6 w-6" fill="none" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          <span>Payment settled! Your balance has been credited.</span>
        </div>

        <!-- Confirmation progress — hidden until a txid appears -->
        <div id="confirm-row" class="hidden">
          <div class="flex justify-between text-sm mb-1">
            <span class="text-base-content/70">Confirmations</span>
            <span id="confirm-count" class="font-mono font-semibold">0 / {required}</span>
          </div>
          <progress id="confirm-bar" class="progress progress-info w-full" value="0" max={required}></progress>
          <p class="text-xs text-base-content/50 mt-1">{confirmHint}</p>
        </div>

        <div class="form-control gap-1">
          <label class="label">
            <span class="label-text font-semibold">Send to this address</span>
          </label>
          <div class="flex items-center gap-2">
            <input
              type="text"
              readonly
              value={address}
              onclick="this.select()"
              class="input input-bordered w-full font-mono text-sm cursor-pointer"
            />
            <button id="copy-btn" class="btn btn-outline btn-sm" title="Copy address">Copy</button>
          </div>
        </div>

        <div class="stats shadow w-full">
          <div class="stat">
            <div class="stat-title">Amount</div>
            <div class="stat-value text-primary text-xl">{amountUsd}</div>
            <div class="stat-desc select-all cursor-text">{amountDecimal} {currency}</div>
          </div>
        </div>

        {currency === 'XMR' ? (
          <div class="alert alert-info text-sm">
            <svg xmlns="http://www.w3.org/2000/svg" class="stroke-current shrink-0 h-5 w-5" fill="none" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
            <span>Monero stagenet — confirmation takes a few minutes once your transaction is broadcast.</span>
          </div>
        ) : isRegtest ? (
          <div class="collapse collapse-arrow bg-base-200">
            <input type="checkbox" />
            <div class="collapse-title font-medium">
              Regtest: mine a block to confirm
            </div>
            <div class="collapse-content">
              <p class="text-xs text-base-content/70 mb-2">
                On regtest, transactions need a mined block to confirm. Run this once per confirmation ({required} times to settle):
              </p>
              <pre class="bg-base-300 rounded p-3 text-xs overflow-x-auto whitespace-pre-wrap break-all"><code>{mineCmd}</code></pre>
            </div>
          </div>
        ) : null}

        <div class="text-xs text-base-content/50">
          Invoice ID: <span class="font-mono">{invoiceId}</span>
        </div>

        <div class="card-actions justify-start">
          <a href="/" class="btn btn-ghost btn-sm">Back to home</a>
        </div>
      </div>
    </div>
  </div>

  <script define:vars={{ invoiceId, PUBLIC_API_URL, required }}>
    const apiBase = PUBLIC_API_URL || '';
    const statusBadge = document.getElementById('status-badge');
    const successAlert = document.getElementById('success-alert');
    const confirmRow = document.getElementById('confirm-row');
    const confirmCount = document.getElementById('confirm-count');
    const confirmBar = document.getElementById('confirm-bar');
    const copyBtn = document.getElementById('copy-btn');

    copyBtn?.addEventListener('click', () => {
      const input = copyBtn.previousElementSibling;
      if (input instanceof HTMLInputElement) {
        navigator.clipboard.writeText(input.value).then(() => {
          const original = copyBtn.textContent;
          copyBtn.textContent = 'Copied!';
          setTimeout(() => { copyBtn.textContent = original; }, 1500);
        });
      }
    });

    let polling = true;

    function updateUI(status, confirmations, txid) {
      if (!statusBadge) return;

      if (status === 'settled') {
        statusBadge.textContent = 'settled';
        statusBadge.className = 'badge badge-lg badge-success';
        successAlert?.classList.remove('hidden');
        confirmRow?.classList.add('hidden');
      } else if (txid) {
        // Transaction seen on-chain, counting confirmations
        statusBadge.textContent = 'confirming';
        statusBadge.className = 'badge badge-lg badge-info';
        confirmRow?.classList.remove('hidden');
        if (confirmCount) confirmCount.textContent = `${confirmations} / ${required}`;
        if (confirmBar) {
          confirmBar.value = confirmations;
          confirmBar.max = required;
        }
      } else {
        // Waiting for payment to appear
        statusBadge.textContent = 'waiting';
        statusBadge.className = 'badge badge-lg badge-warning';
        confirmRow?.classList.add('hidden');
      }
    }

    async function pollStatus() {
      if (!polling) return;
      try {
        const res = await fetch(`${apiBase}/api/deposits/status/${invoiceId}`);
        if (res.ok) {
          const data = await res.json();
          updateUI(data.status, data.confirmations ?? 0, data.txid ?? null);
          if (data.status === 'settled') polling = false;
        }
      } catch { /* ignore */ }
      if (polling) setTimeout(pollStatus, 5000);
    }

    void pollStatus();
  </script>
</Layout>
