---
import Layout from '../../layouts/Layout.astro';
import { getPrices, satsToUsd, litoshisToUsd, piconerosToUsd, formatUsd } from '../../lib/prices';

const token = Astro.cookies.get('token')?.value;
if (!token) return Astro.redirect('/login');

const { invoiceId } = Astro.params;
const urlParams = new URL(Astro.request.url).searchParams;
const address = urlParams.get('address') ?? '';
const amountSatsRaw = urlParams.get('amountSats') ?? '0';
const currency = urlParams.get('currency') ?? 'BTC';
const amountSats = Number(amountSatsRaw);
const [divisor, decimals] = currency === 'XMR' ? [1e12, 12] : [1e8, 8];
const amountDecimal = (amountSats / divisor).toFixed(decimals).replace(/\.?0+$/, '');

const prices = await getPrices();
const amountUsd = formatUsd(
  currency === 'XMR' ? piconerosToUsd(amountSats, prices.xmrUsd) :
  currency === 'LTC' ? litoshisToUsd(amountSats, prices.ltcUsd) :
  satsToUsd(amountSats, prices.btcUsd),
);

const PUBLIC_API_URL = import.meta.env.PUBLIC_API_URL || '';
const isRegtest = process.env.NETWORK === 'regtest';

const mineCmd =
  currency === 'LTC'
    ? `kubectl exec -n crypto-demo deployment/litecoind -- litecoin-cli -regtest -rpcuser=litecoin -rpcpassword=changeme generatetoaddress 1 ${address}`
    : `kubectl exec -n crypto-demo deployment/bitcoind -- bitcoin-cli -regtest -rpcuser=bitcoin -rpcpassword=changeme generatetoaddress 1 ${address}`;
---

<Layout title="Pay Invoice">
  <div class="min-h-screen flex flex-col items-center justify-center p-4">
    <div class="card w-full max-w-lg bg-base-100 shadow-xl">
      <div class="card-body gap-5">
        <div class="flex items-center justify-between">
          <h1 class="card-title text-2xl">{currency} Payment</h1>
          <span id="status-badge" class="badge badge-warning badge-lg">pending</span>
        </div>

        <div id="success-alert" class="alert alert-success hidden">
          <svg xmlns="http://www.w3.org/2000/svg" class="stroke-current shrink-0 h-6 w-6" fill="none" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          <span>Payment settled! Your balance has been credited.</span>
        </div>

        <div class="form-control gap-1">
          <label class="label">
            <span class="label-text font-semibold">Send to this address</span>
          </label>
          <div class="flex items-center gap-2">
            <input
              type="text"
              readonly
              value={address}
              onclick="this.select()"
              class="input input-bordered w-full font-mono text-sm cursor-pointer"
            />
            <button id="copy-btn" class="btn btn-outline btn-sm" title="Copy address">Copy</button>
          </div>
        </div>

        <div class="stats shadow w-full">
          <div class="stat">
            <div class="stat-title">Amount</div>
            <div class="stat-value text-primary text-xl">{amountUsd}</div>
            <div class="stat-desc select-all cursor-text">{amountDecimal} {currency}</div>
          </div>
        </div>

        {currency === 'XMR' ? (
          <div class="alert alert-info text-sm">
            <svg xmlns="http://www.w3.org/2000/svg" class="stroke-current shrink-0 h-5 w-5" fill="none" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
            <span>Monero stagenet — confirmation takes a few minutes once your transaction is broadcast.</span>
          </div>
        ) : isRegtest ? (
          <div class="collapse collapse-arrow bg-base-200">
            <input type="checkbox" />
            <div class="collapse-title font-medium">
              Regtest: mine a block to confirm
            </div>
            <div class="collapse-content">
              <p class="text-xs text-base-content/70 mb-2">
                On regtest, transactions need a mined block to settle. Run:
              </p>
              <pre class="bg-base-300 rounded p-3 text-xs overflow-x-auto whitespace-pre-wrap break-all"><code id="mine-cmd">{mineCmd}</code></pre>
            </div>
          </div>
        ) : null}

        <div class="text-xs text-base-content/50">
          Invoice ID: <span class="font-mono">{invoiceId}</span>
        </div>

        <div class="card-actions justify-start">
          <a href="/" class="btn btn-ghost btn-sm">Back to home</a>
        </div>
      </div>
    </div>
  </div>

  <script define:vars={{ invoiceId, PUBLIC_API_URL }}>
    const apiBase = PUBLIC_API_URL || '';
    const statusBadge = document.getElementById('status-badge');
    const successAlert = document.getElementById('success-alert');
    const copyBtn = document.getElementById('copy-btn');

    copyBtn?.addEventListener('click', () => {
      const input = copyBtn.previousElementSibling;
      if (input instanceof HTMLInputElement) {
        navigator.clipboard.writeText(input.value).then(() => {
          const original = copyBtn.textContent;
          copyBtn.textContent = 'Copied!';
          setTimeout(() => { copyBtn.textContent = original; }, 1500);
        });
      }
    });

    let polling = true;

    function updateBadge(status) {
      if (!statusBadge) return;
      statusBadge.textContent = status;
      statusBadge.className = 'badge badge-lg';
      if (status === 'settled') statusBadge.classList.add('badge-success');
      else if (status === 'pending') statusBadge.classList.add('badge-warning');
      else statusBadge.classList.add('badge-error');
    }

    async function pollStatus() {
      if (!polling) return;
      try {
        const res = await fetch(`${apiBase}/api/deposits/status/${invoiceId}`);
        if (res.ok) {
          const data = await res.json();
          updateBadge(data.status);
          if (data.status === 'settled') {
            polling = false;
            if (successAlert) successAlert.classList.remove('hidden');
          }
        }
      } catch { /* ignore */ }
      if (polling) setTimeout(pollStatus, 5000);
    }

    setTimeout(pollStatus, 5000);
  </script>
</Layout>
