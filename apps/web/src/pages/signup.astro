---
import Layout from '../layouts/Layout.astro';
const API_URL = process.env.API_URL || 'http://localhost:3000';
let error = '';

if (Astro.request.method === 'POST') {
  const data = await Astro.request.formData();
  const username = data.get('username') as string;
  const password = data.get('password') as string;

  try {
    const res = await fetch(`${API_URL}/api/auth/signup`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ username, password }),
    });

    if (res.ok) {
      const { access_token } = await res.json();
      Astro.cookies.set('token', access_token, {
        httpOnly: true,
        path: '/',
        maxAge: 60 * 60 * 24 * 7,
        sameSite: 'lax',
      });
      return Astro.redirect('/');
    } else {
      const body = await res.json();
      error = Array.isArray(body.message) ? body.message[0] : (body.message ?? 'Signup failed');
    }
  } catch {
    error = 'Could not reach API';
  }
}
---

<Layout title="Sign Up — Crypto Demo">
  <div class="min-h-screen flex items-center justify-center p-4">
    <div class="card w-full max-w-sm bg-base-100 shadow-xl">
      <div class="card-body gap-4">
        <h1 class="card-title text-2xl">Sign Up</h1>

        {error && (
          <div role="alert" class="alert alert-error text-sm">{error}</div>
        )}

        <form method="POST" class="flex flex-col gap-3">
          <label class="form-control">
            <div class="label"><span class="label-text">Username</span></div>
            <input type="text" name="username" minlength="3" required class="input input-bordered w-full" />
            <div class="label"><span class="label-text-alt">At least 3 characters</span></div>
          </label>

          <label class="form-control">
            <div class="label"><span class="label-text">Password</span></div>
            <input type="password" name="password" minlength="8" required class="input input-bordered w-full" />
            <div class="label"><span class="label-text-alt">Minimum 8 characters</span></div>
          </label>

          <button type="submit" class="btn btn-primary w-full mt-2">Create account</button>
        </form>

        <p class="text-sm text-center">
          Already have an account? <a href="/login" class="link link-primary">Log in</a>
        </p>
      </div>
    </div>
  </div>
</Layout>
