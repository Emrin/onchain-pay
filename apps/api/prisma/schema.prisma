generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           Int           @id @default(autoincrement())
  username          String        @unique
  passwordHash      String        @default("")
  mnemonicHash      String        @default("")
  mnemonicConfirmed Boolean       @default(false)
  balanceSats       BigInt        @default(0)
  balanceLitoshi    BigInt        @default(0)
  balancePiconero   BigInt        @default(0)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  transactions Transaction[]
}

model ExchangeRate {
  pair      String   @id        // e.g. "BTC_USD", "LTC_USD"
  rate      Float
  updatedAt DateTime @updatedAt
}

model Transaction {
  id            Int       @id @default(autoincrement())
  userId        Int
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  invoiceId     String    @unique
  amountSats    BigInt
  address       String    @default("")
  currency      String    @default("BTC")
  status        String    @default("pending")
  confirmations Int       @default(0)
  txid          String?
  subaddrIndex  Int?
  expiresAt     DateTime?
  deletedAt     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([address])
  @@index([status, expiresAt])
}

model WalletConfig {
  currency  String @id
  xpub      String
  nextIndex Int    @default(0)
}
